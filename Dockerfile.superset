FROM apache/superset:latest

USER root

# Install specifically into the site-packages directory where Superset looks
RUN pip install --no-cache-dir --target /app/.venv/lib/python3.10/site-packages psycopg2-binary

# Copy config
COPY superset_config.py /app/pythonpath/superset_config.py

# Fix permissions
RUN chown -R superset:superset /app/pythonpath/superset_config.py

USER superset
